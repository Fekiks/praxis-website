---
/** Inline SVG — Diptychon wie Original: weiße Köpfe, Chaos/Spirale darauf, Außenlinie oben drauf; durchgehende Mund-Linie. */

const skullLeft =
  "M 146 296 C 130 296 116 278 114 248 C 108 178 138 118 204 106 C 268 94 336 126 366 182 C 392 228 382 278 356 298 C 344 308 332 318 318 324 L 314 328 C 306 342 284 348 258 336 C 236 324 226 294 228 258 C 228 226 204 212 182 226 C 162 238 154 266 164 292 Z";

const skullRight =
  "M 782 296 C 798 296 812 278 814 248 C 820 178 790 118 724 106 C 660 94 592 126 562 182 C 536 228 546 278 572 298 C 584 308 596 318 610 324 L 614 328 C 622 342 644 348 670 336 C 692 324 702 294 700 258 C 700 226 724 212 746 226 C 766 238 774 266 764 292 Z";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 928 372"
  role="img"
  aria-labelledby="hero-diptych-title"
  class="therapy-diptych"
>
  <title id="hero-diptych-title">
    Von innerer Unruhe zu Klarheit – Symbol für Psychotherapie
  </title>

  <defs>
    <clipPath id="hero-diptych-skull-left">
      <path d={skullLeft}></path>
    </clipPath>
    <clipPath id="hero-diptych-skull-right">
      <path d={skullRight}></path>
    </clipPath>
  </defs>

  <rect width="928" height="372" fill="#e8e0d4"></rect>

  <!-- Linkes Feld -->
  <rect x="14" y="18" width="438" height="336" rx="11" ry="11" fill="#121212"></rect>
  <rect x="28" y="32" width="11" height="308" fill="#f6f3eb"></rect>
  <rect x="41" y="32" width="397" height="308" fill="#bfb5a8"></rect>

  <!-- Weiße Kopffläche → Chaos darauf → Außenlinie -->
  <path fill="#fafafa" stroke="none" d={skullLeft}></path>
  <g
    clip-path="url(#hero-diptych-skull-left)"
    fill="none"
    stroke="#121212"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path
      d="M 258 132 C 298 118 328 148 314 182 C 300 218 252 212 246 172 C 242 148 266 138 292 152"
    ></path>
    <path
      d="M 276 148 C 318 158 324 198 286 216 C 248 236 218 188 246 158 C 258 146 274 146 296 158"
    ></path>
    <path
      d="M 248 178 C 278 158 318 172 306 212 C 294 248 246 238 238 198 C 234 172 258 158 284 172"
    ></path>
    <path d="M 292 158 C 328 172 324 218 284 226 C 242 236 226 185 258 162"></path>
    <path d="M 268 168 C 306 148 332 188 298 218 C 266 246 228 212 238 178"></path>
  </g>
  <path fill="none" stroke="#121212" stroke-width="2.4" stroke-linejoin="round" d={skullLeft}
  ></path>

  <!-- Rechtes Feld -->
  <rect x="476" y="18" width="438" height="336" rx="11" ry="11" fill="#121212"></rect>
  <rect x="490" y="32" width="397" height="308" fill="#bfb5a8"></rect>
  <rect x="887" y="32" width="11" height="308" fill="#f6f3eb"></rect>

  <path fill="#fafafa" stroke="none" d={skullRight}></path>
  <path
    fill="none"
    stroke="#121212"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"
    clip-path="url(#hero-diptych-skull-right)"
    d="M 716 206 C 766 206 798 158 774 118 C 752 82 698 76 668 106 C 638 138 646 188 682 206 C 716 224 758 206 764 166 C 772 126 738 94 702 102 C 668 110 654 146 668 174 C 682 202 716 212 744 194 C 766 178 766 146 744 126 C 726 110 698 118 688 138 C 680 154 692 174 712 178 C 726 182 742 172 744 156"
  ></path>
  <path fill="none" stroke="#121212" stroke-width="2.4" stroke-linejoin="round" d={skullRight}
  ></path>

  <!-- Linie zwischen den Mündern durch den Spalt -->
  <path fill="none" stroke="#121212" stroke-width="3" stroke-linecap="round" d="M 426 236 L 502 236"
  ></path>
</svg>

<style>
  .therapy-diptych {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
    border-radius: 12px;
  }
</style>
