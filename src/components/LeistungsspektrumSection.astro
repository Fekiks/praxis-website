---
/**
 * Leistungsspektrum-Block auf der Startseite („Wann … sinnvoll?").
 * Jede Kachel verlinkt auf eine eigene Unterseite unter /spektrum/[slug].
 */

const tiles = [
  { label: "Depressionen",                         slug: "depressionen" },
  { label: "Angststörungen",                        slug: "angststoerungen" },
  { label: "Zwangsstörungen",                       slug: "zwangsstoerungen" },
  { label: "Essstörungen",                          slug: "essstoerungen" },
  { label: "Trauma",                                slug: "trauma" },
  { label: "Komplizierte Trauer",                   slug: "komplizierte-trauer" },
  { label: "Psychosomatische Störungen",            slug: "psychosomatische-stoerungen" },
  { label: "Schlafstörungen",                       slug: "schlaftstoerungen" },
  { label: "Burnout und chronische Überforderung",  slug: "burnout" },
  { label: "AD(H)S",                               slug: "adhs" },
  { label: "Autismus-Spektrum",                     slug: "autismus-spektrum" },
  { label: "Selbstwert und zwischenmenschliche Muster", slug: "selbstwert" },
];
---

<section
  class="content-block lei-spektrum-root lei-spektrum-root--home"
  aria-labelledby="psychotherapie-wann-h2"
  id="psychotherapie-wann"
>
  <h2 id="psychotherapie-wann-h2">Wann ist Psychotherapie sinnvoll?</h2>
  <p class="lei-spektrum-intro">
    Psychotherapie kann dann helfen, wenn Sie spüren, dass{" "}
    <strong>Belastung, Ängste, Niedergeschlagenheit oder Krisen</strong> Ihr Leben über längere Zeit spürbar
    einschränken — und wenn Sie mehr <strong>Struktur, Entlastung und professionelle Begleitung</strong> wünschen, als
    Freundeskreis oder Selbsthilfe allein aktuell bieten können.
  </p>

  <div class="spektrum-grid" role="list">
    {tiles.map((tile) => (
      <a
        href={`/spektrum/${tile.slug}`}
        class="spektrum-tile"
        role="listitem"
      >
        <span class="spectrum-cat">{tile.label}</span>
      </a>
    ))}
  </div>

  <p class="lei-spektrum-footer">
    <a href="/services/" class="cta">Zu Kosten und Absicherung</a>
  </p>
</section>

<style>
  .lei-spektrum-root--home :global(h2) {
    margin: 0 0 1rem;
    line-height: 1.28;
  }

  .lei-spektrum-intro {
    margin: 0 0 1.1rem;
    line-height: 1.78;
    max-width: none;
    text-align: justify;
    hyphens: auto;
  }

  .lei-spektrum-footer {
    margin: 1.35rem 0 0;
    text-align: center;
  }

  /* Grid */
  .spektrum-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin: 20px 0 18px;
    align-items: stretch;
  }

  @media (max-width: 768px) {
    .spektrum-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }

  @media (max-width: 480px) {
    .spektrum-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Tile */
  .spektrum-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 72px;
    padding: 14px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: #e2d8cf;
    box-shadow: 0 12px 36px var(--shadow);
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition:
      background-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.12s ease;
  }

  .spektrum-tile:hover,
  .spektrum-tile:focus-visible {
    background: #d5c9be;
    box-shadow: 0 16px 40px var(--shadow);
    transform: translateY(-2px);
  }

  .spektrum-tile:active {
    transform: translateY(0);
  }

  .spectrum-cat {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.12rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }
</style>
