---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "about-mitgliedschaften");

if (!entry) {
  throw new Error('Eintrag "about-mitgliedschaften" in Collection "pages" nicht gefunden.');
}

const { Content } = await render(entry);
---

<BaseLayout
  layout="stacked"
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.description}
>
  <div class="home-sections about-subpage">
    <p class="about-back">
      <a href="/about/">← Zurück zu Über mich</a>
    </p>
    <Content />
  </div>
</BaseLayout>

<style>
  .about-subpage :global(.content-block p) {
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  .about-subpage :global(.content-block h3) {
    margin: 1.35em 0 0.5em;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.18rem;
    font-weight: 600;
    color: var(--ink);
  }

  .about-subpage :global(.content-block h3:first-of-type) {
    margin-top: 0.85em;
  }

  .about-back {
    margin: 0 0 22px;
    font-size: 0.95rem;
  }

  .about-back a {
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
  }

  .about-back a:hover,
  .about-back a:focus-visible {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
