---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "index");

if (!entry) {
  throw new Error('Eintrag "index" nicht gefunden.');
}

const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} layout="home">
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-copy">
      <p class="hero-eyebrow">Psychologische Psychotherapie</p>
      <h1 id="hero-heading">Herzlich willkommen</h1>
      <p class="hero-lead">
        Ich freue mich, dass Sie den Weg auf meine Website gefunden haben. In meiner Praxis
        begleite ich Sie bei psychischen Belastungen und in schwierigen Lebensphasen – in einem
        geschützten und vertrauensvollen Rahmen.
      </p>
      <a href="/contact" class="cta">Erstgespräch anfragen</a>
    </div>
    <figure class="hero-art">
      <div class="hero-art-frame">
        <img
          src="/images/therapie-diptychon.svg"
          alt="Symbolbild: Von innerer Unruhe zu Klarheit im therapeutischen Gespräch"
          width="920"
          height="480"
          loading="eager"
          decoding="async"
        />
      </div>
      <figcaption class="hero-caption">
        Gemeinsam Ordnung finden – Schritt für Schritt, in Ihrem Tempo.
      </figcaption>
    </figure>
  </section>

  <div class="home-sections">
    <Content />
  </div>
</BaseLayout>

<style>
  .hero {
    width: min(1120px, calc(100% - 32px));
    margin: clamp(28px, 5vw, 56px) auto clamp(20px, 4vw, 40px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 46%);
    gap: clamp(28px, 4vw, 48px);
    align-items: center;
  }

  .hero-eyebrow {
    margin: 0 0 10px;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
  }

  .hero-lead {
    margin: 0;
    max-width: 38ch;
    font-size: clamp(1.02rem, 1.6vw, 1.12rem);
    color: var(--text);
  }

  .hero-art {
    margin: 0;
  }

  .hero-art-frame {
    padding: 10px;
    background: var(--ink);
    border-radius: 20px;
    box-shadow:
      0 28px 70px var(--shadow-strong),
      0 8px 24px var(--shadow);
  }

  .hero-art img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  .hero-caption {
    margin-top: 14px;
    text-align: center;
    font-size: 0.92rem;
    color: var(--muted);
    font-style: italic;
  }

  .home-sections {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto 48px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .home-sections :global(section.content-block) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: clamp(24px, 3.5vw, 40px);
    box-shadow: 0 16px 44px var(--shadow);
  }

  .home-sections :global(section.content-block.highlight) {
    background: linear-gradient(135deg, rgba(200, 185, 166, 0.28), rgba(250, 248, 245, 0.95));
    border-color: var(--taupe-deep);
  }

  .home-sections :global(hr) {
    display: none;
  }

  .home-sections :global(h2:first-child) {
    margin-top: 0;
  }

  .home-sections :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-art {
      order: -1;
    }

    .hero-lead {
      max-width: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      width: calc(100% - 20px);
    }

    .home-sections {
      width: calc(100% - 20px);
    }
  }
</style>
