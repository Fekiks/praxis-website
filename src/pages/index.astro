---
import BaseLayout from "../layouts/BaseLayout.astro";
import LeistungsspektrumSection from "../components/LeistungsspektrumSection.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "index");
const tail = await getEntry("pages", "index-tail");

if (!entry) {
  throw new Error('Eintrag "index" nicht gefunden.');
}
if (!tail) {
  throw new Error('Eintrag "index-tail" nicht gefunden.');
}

const { Content: ContentLead } = await render(entry);
const { Content: ContentTail } = await render(tail);

const heroHeadsSrc = `${import.meta.env.BASE_URL}images/Bild_Praxis_koepfe.jpg`;
---

<BaseLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.description}
  layout="home"
>
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-copy">
      <p class="hero-eyebrow">Psychologische Psychotherapie</p>
      <h1 id="hero-heading">Herzlich willkommen</h1>
      <p class="hero-lead">
        Ich freue mich, dass Sie den Weg auf meine Website gefunden haben. In meiner Praxis
        begleite ich Sie bei psychischen Belastungen und in schwierigen Lebensphasen – in einem
        geschützten und vertrauensvollen Rahmen.
      </p>
      <a href="/contact" class="cta">Erstgespräch anfragen</a>
    </div>
    <figure class="hero-art">
      <div class="hero-art-frame">
        <img
          src={heroHeadsSrc}
          alt="Diptychon: vom Gedankenknoten zur inneren Ordnung im therapeutischen Gespräch"
          width="1796"
          height="849"
          class="hero-art-img"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
      <figcaption class="hero-caption">
        Gemeinsam Ordnung finden – Schritt für Schritt, in Ihrem Tempo.
      </figcaption>
    </figure>
  </section>

  <div class="home-sections">
    <ContentLead />
    <LeistungsspektrumSection />
    <ContentTail />
  </div>
</BaseLayout>

<style>
  .hero {
    width: min(1120px, calc(100% - 32px));
    margin: clamp(28px, 5vw, 56px) auto clamp(20px, 4vw, 40px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 46%);
    gap: clamp(28px, 4vw, 48px);
    align-items: center;
  }

  .hero-copy {
    min-width: 0;
  }

  /* CTA näher an den Text heran */
  .hero-copy :global(.cta) {
    margin-top: 10px;
  }

  .hero-eyebrow {
    margin: 0 0 10px;
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--taupe-deep);
    font-weight: 600;
  }

  .hero-lead {
    margin: 0;
    max-width: none;
    font-size: clamp(1.05rem, 1.6vw, 1.14rem);
    color: var(--text);
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  .hero-art {
    margin: 0;
  }

  .hero-art-frame {
    padding: 3px;
    background: linear-gradient(145deg, var(--accent), #8a7060);
    border-radius: 14px;
    box-shadow:
      0 24px 60px rgba(28, 20, 12, 0.10),
      0 6px 20px rgba(74, 52, 40, 0.20);
  }

  .hero-art-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
    vertical-align: middle;
  }

  .hero-caption {
    margin-top: 14px;
    text-align: center;
    font-size: 1.10rem;
    color: var(--muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      width: calc(100% - 16px);
      margin-top: 8px;
      margin-bottom: 12px;
      gap: 34px;
    }

    /* Bild zuerst, volle Breite */
    .hero-art {
      order: -1;
      width: 100%;
      max-width: none;
      margin: 0;
    }

    /* Bildunterschrift auf Handy weglassen */
    .hero-caption {
      display: none;
    }

    .hero-lead {
      max-width: none;
      font-size: 0.97rem;
    }

    /* Eyebrow auf Handy ausblenden */
    .hero-eyebrow {
      display: none;
    }

    .hero-copy h1 {
      margin: 0 0 14px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      gap: 10px;
    }
  }
</style>
