---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "about");

if (!entry) {
  throw new Error('Eintrag "about" in Collection "pages" nicht gefunden.');
}

const { Content } = await render(entry);

const portraitSrc = `${import.meta.env.BASE_URL}images/Bild_Katja.jpg`;
---

<BaseLayout title={entry.data.seoTitle ?? entry.data.title} description={entry.data.description}>
  <div class="about-layout">
    <div class="about-content">
      <Content />
    </div>
    <aside class="about-portrait" aria-label="Portrait">
      <figure class="about-portrait-frame">
        <img
          src={portraitSrc}
          alt="Portrait von Katja Stumper"
          width="1254"
          height="1254"
          sizes="(max-width: 820px) min(280px, 88vw), 260px"
          class="about-portrait-img"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="about-portrait-caption">Katja Stumper</figcaption>
      </figure>
    </aside>
  </div>
</BaseLayout>

<style>
  .about-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(200px, 268px);
    gap: clamp(28px, 4vw, 44px);
    align-items: start;
  }

  .about-content {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }

  .about-content :global(p),
  .about-content :global(li) {
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  .about-portrait {
    grid-column: 2;
    grid-row: 1;
    position: sticky;
    top: 88px;
  }

  .about-portrait-frame {
    margin: 0;
  }

  .about-portrait-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 22px;
    border: 1px solid var(--border);
    box-shadow:
      0 20px 48px rgba(20, 20, 20, 0.11),
      0 6px 18px rgba(20, 20, 20, 0.06);
  }

  .about-portrait-caption {
    margin: 12px 0 0;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--muted);
    text-align: center;
    letter-spacing: 0.02em;
  }

  .about-content :global(p:first-of-type) {
    font-size: 1.04rem;
    font-weight: 400;
    line-height: 1.7;
  }

  @media (max-width: 820px) {
    .about-layout {
      grid-template-columns: 1fr;
    }

    .about-portrait {
      grid-column: 1;
      grid-row: 1;
      position: static;
      justify-self: center;
      max-width: 288px;
      width: 100%;
      margin-bottom: 6px;
    }

    .about-content {
      grid-column: 1;
      grid-row: 2;
    }
  }
</style>
