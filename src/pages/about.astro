---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "about");

if (!entry) {
  throw new Error('Eintrag "about" in Collection "pages" nicht gefunden.');
}

const { Content } = await render(entry);

const portraitSrc = `${import.meta.env.BASE_URL}images/Bild_Katja.jpg`;
---

<BaseLayout
  layout="stacked"
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.description}
>
  <div class="about-layout" id="about-page-root">
    <div class="about-content">
      <div class="home-sections about-page">
        <Content />
      </div>
    </div>
    <aside class="about-portrait" aria-label="Portrait">
      <figure class="about-portrait-frame">
        <img
          src={portraitSrc}
          alt="Portrait von Katja Stumper"
          width="1254"
          height="1254"
          sizes="(max-width: 820px) min(280px, 88vw), 260px"
          class="about-portrait-img"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="about-portrait-caption">
          <span class="about-portrait-name">Katja Stumper</span>
          <span class="about-portrait-qual">
            Psychologische Psychotherapeutin (VT) und Psychologin M.Sc.
          </span>
        </figcaption>
      </figure>
    </aside>
  </div>
</BaseLayout>

<style>
  .about-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(200px, 268px);
    gap: clamp(28px, 4vw, 44px);
    align-items: start;
  }

  .about-content {
    grid-column: 1;
    grid-row: 1;
    min-width: 0;
  }

  .about-content :global(p) {
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  .about-content :global(li) {
    text-align: start;
    hyphens: manual;
  }

  /* Aufklappbare Abschnitte (wie Leistungen/Kosten) */
  .about-content :global(.about-page .accordion-stack) {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 18px 0 0;
  }

  .about-content :global(.about-page .accordion-item) {
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--card-bg);
    box-shadow: 0 12px 36px var(--shadow);
    overflow: hidden;
  }

  .about-content :global(.about-page .accordion-item summary) {
    padding: 16px 18px;
    cursor: pointer;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 600;
    font-size: 1.12rem;
    color: var(--ink);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    line-height: 1.3;
  }

  .about-content :global(.about-page .accordion-item summary::-webkit-details-marker) {
    display: none;
  }

  .about-content :global(.about-page .accordion-item summary::after) {
    content: "";
    width: 0.5em;
    height: 0.5em;
    border-right: 2px solid var(--muted);
    border-bottom: 2px solid var(--muted);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-top: -0.2em;
  }

  .about-content :global(.about-page .accordion-item[open] summary::after) {
    transform: rotate(-135deg);
    margin-top: 0.15em;
  }

  .about-content :global(.about-page .accordion-body) {
    padding: 14px 18px 18px;
    border-top: 1px solid var(--border);
    background: rgba(250, 248, 245, 0.45);
  }

  .about-content :global(.about-page .accordion-body p) {
    margin: 0 0 14px;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    font-size: 1.02rem;
    line-height: 1.68;
    color: var(--text);
  }

  .about-content :global(.about-page .accordion-body p:last-child) {
    margin-bottom: 0;
  }

  .about-content :global(.about-page .about-qual-accordion .accordion-body p),
  .about-content :global(.about-page .about-qual-accordion .accordion-body li) {
    text-align: start;
    hyphens: manual;
    word-spacing: normal;
  }

  .about-content :global(.about-accordion-section > p:first-of-type) {
    margin: 0 0 4px;
  }

  .about-portrait {
    grid-column: 2;
    grid-row: 1;
    position: sticky;
    top: 88px;
  }

  .about-portrait-frame {
    margin: 0;
  }

  .about-portrait-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 22px;
    border: 1px solid var(--border);
    box-shadow:
      0 20px 48px rgba(20, 20, 20, 0.11),
      0 6px 18px rgba(20, 20, 20, 0.06);
  }

  .about-portrait-caption {
    margin: 12px 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .about-portrait-name {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.02em;
    line-height: 1.25;
  }

  .about-portrait-qual {
    font-family: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--muted);
    max-width: 100%;
  }

  .about-content :global(.home-sections section.content-block:first-of-type p:first-of-type) {
    font-size: 1.04rem;
    font-weight: 400;
    line-height: 1.7;
  }

  @media (max-width: 820px) {
    .about-layout {
      grid-template-columns: 1fr;
    }

    .about-portrait {
      grid-column: 1;
      grid-row: 1;
      position: static;
      justify-self: center;
      max-width: 288px;
      width: 100%;
      margin-bottom: 6px;
    }

    .about-content {
      grid-column: 1;
      grid-row: 2;
    }
  }
</style>
