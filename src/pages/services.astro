---
import BaseLayout from "../layouts/BaseLayout.astro";
import LeistungsspektrumSection from "../components/LeistungsspektrumSection.astro";
import { getEntry, render } from "astro:content";

const intro = await getEntry("pages", "services-intro");
const rest = await getEntry("pages", "services-rest");

if (!intro) {
  throw new Error('Eintrag "services-intro" nicht gefunden.');
}
if (!rest) {
  throw new Error('Eintrag "services-rest" nicht gefunden.');
}

const { Content: ContentIntro } = await render(intro);
const { Content: ContentRest } = await render(rest);
---

<BaseLayout
  layout="stacked"
  title={intro.data.seoTitle ?? intro.data.title}
  description={intro.data.description}
>
  <div class="home-sections services-page">
    <ContentIntro />
    <LeistungsspektrumSection variant="services" />
    <ContentRest />
  </div>
</BaseLayout>

<style>
  /* Aufklappbare Kosten-Infos (.accordion-stack ohne --spectrum liegt in Markdown) */

  .services-page :global(.accordion-stack) {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 20px 0 18px;
  }

  .services-page :global(.accordion-item) {
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--card-bg);
    box-shadow: 0 12px 36px var(--shadow);
    overflow: hidden;
  }

  .services-page :global(.accordion-item summary) {
    padding: 16px 18px;
    cursor: pointer;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 600;
    font-size: 1.12rem;
    color: var(--ink);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    line-height: 1.3;
  }

  .services-page :global(.accordion-item summary::-webkit-details-marker) {
    display: none;
  }

  .services-page :global(.accordion-item summary::after) {
    content: "";
    width: 0.5em;
    height: 0.5em;
    border-right: 2px solid var(--muted);
    border-bottom: 2px solid var(--muted);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-top: -0.2em;
  }

  .services-page :global(.accordion-item[open] summary::after) {
    transform: rotate(-135deg);
    margin-top: 0.15em;
  }

  .services-page :global(.accordion-body) {
    padding: 14px 18px 18px;
    border-top: 1px solid var(--border);
    background: rgba(239, 232, 223, 0.58);
  }

  .services-page :global(.accordion-body p) {
    margin: 0 0 14px;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    font-size: 1.02rem;
    line-height: 1.68;
    color: var(--text);
  }

  .services-page :global(.accordion-body p:last-child) {
    margin-bottom: 0;
  }

  /* Leistungsseite (stacked): typografische Angleichung an andere Content-Blöcke */
  .services-page :global(section.content-block h2) {
    margin-bottom: 1.2rem;
    line-height: 1.28;
  }

  .services-page :global(section.content-block > h2:first-of-type) {
    margin-top: 0;
  }

  .services-page :global(section.content-block p) {
    margin: 0 0 1.2rem;
    max-width: 62ch;
    line-height: 1.78;
  }

  .services-page :global(section.content-block p:last-child) {
    margin-bottom: 0;
  }

  .services-page :global(.follow-text-cta) {
    margin-top: 0.35rem;
  }
</style>
