---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "datenschutz");
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.seoTitle ?? entry.data.title} description={entry.data.description} layout="stacked">
  <div class="home-sections">
    <Content />
  </div>
</BaseLayout>