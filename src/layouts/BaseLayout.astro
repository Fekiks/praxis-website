---
import {
  DEFAULT_META_DESCRIPTION,
  FOOTER_MARK,
  PRACTICE,
} from "../site-config";

interface Props {
  title: string;
  description?: string;
  layout?: "default" | "home" | "stacked";
  noindex?: boolean;
}

const { title, description, layout = "default", noindex = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = layout === "home";
const isStacked = layout === "stacked";

const mainLayoutClass = isHome ? "layout-home" : isStacked ? "layout-stacked" : "layout-default";

const metaDescription = (description ?? DEFAULT_META_DESCRIPTION).trim();

const siteBaseHref = Astro.site
  ? Astro.site.href.endsWith("/")
    ? Astro.site.href
    : `${Astro.site.href}/`
  : null;

const pathClean = Astro.url.pathname.replace(/^\/+|\/+$/g, "");
const canonicalRel = pathClean === "" ? "./" : `${pathClean}/`;

const canonicalURL =
  siteBaseHref !== null ? new URL(canonicalRel, siteBaseHref) : null;
const canonicalHref = canonicalURL?.href ?? null;

const rootUrl =
  siteBaseHref !== null ? siteBaseHref.replace(/\/+$/, "") || siteBaseHref : null;

/** Hero-Unterlage unter `public/images/` für OG/Twitter/Schema.org (Fußbereich ohne Logo-Grafik). */
const shareImageRelative = "images/Bild_Praxis_koepfe.jpg";
const shareImageAbsoluteHref =
  siteBaseHref !== null ? new URL(shareImageRelative, siteBaseHref).href : null;

const appleTouchIconRelative = "images/Bild_Katja.jpg";
const appleTouchIconAbsoluteHref =
  siteBaseHref !== null ? new URL(appleTouchIconRelative, siteBaseHref).href : null;

const footerMarkSrc = `${import.meta.env.BASE_URL}${FOOTER_MARK.file}`;
const footerMarkAbsoluteHref =
  siteBaseHref !== null ? new URL(FOOTER_MARK.file, siteBaseHref).href : null;

/** Social-Vorschau: Fußgrafik wenn vorhanden, sonst Praxis-/Hero-JPEG */
const ogImageHref =
  footerMarkAbsoluteHref ?? shareImageAbsoluteHref;

const structuredDataJson =
  Astro.site && siteBaseHref && rootUrl && !noindex
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "MedicalBusiness",
            "@id": `${rootUrl}#practice`,
            name: PRACTICE.siteName,
            alternateName: [
              "Psychotherapie Katja Stumper Köln",
              "Psychotherapiepraxis Köln Bayenthal",
            ],
            description: DEFAULT_META_DESCRIPTION.trim(),
            url: rootUrl,
            ...(footerMarkAbsoluteHref
              ? {
                  logo: {
                    "@type": "ImageObject",
                    url: footerMarkAbsoluteHref,
                    width: FOOTER_MARK.width,
                    height: FOOTER_MARK.height,
                  },
                  image: [footerMarkAbsoluteHref],
                }
              : shareImageAbsoluteHref
                ? { image: [shareImageAbsoluteHref] }
                : {}),
            telephone: PRACTICE.telephone,
            email: PRACTICE.email,
            address: {
              "@type": "PostalAddress",
              streetAddress: PRACTICE.streetAddress,
              addressLocality: PRACTICE.addressLocality,
              postalCode: PRACTICE.postalCode,
              addressRegion: PRACTICE.addressRegion,
              addressCountry: PRACTICE.country,
            },
            areaServed: {
              "@type": "City",
              name: "Köln",
              containedInPlace: {
                "@type": "AdministrativeArea",
                name: "Nordrhein-Westfalen",
              },
            },
            currenciesAccepted: "EUR",
            paymentAccepted:
              "Gesetzliche Krankenkassen, Privatversicherung, Selbstzahlung",
            medicalSpecialty: "Psychotherapy",
            knowsAbout: [
              "Verhaltenstherapie",
              "Expositionstherapie",
              "Acceptance and Commitment Therapy",
              "EMDR",
            ],
          },
          {
            "@type": "Person",
            "@id": `${rootUrl}#person`,
            name: PRACTICE.practitionerName,
            jobTitle: "Psychologische Psychotherapeutin",
            worksFor: { "@id": `${rootUrl}#practice` },
          },
        ],
      })
    : null;

const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";

const isActive = (path: string) => {
  const cur = normalizePath(currentPath);
  const target = normalizePath(path);
  if (target === "/") return cur === "/";
  return cur === target || cur.startsWith(`${target}/`);
};

/** Nur bei Vercel-Build gesetzt – zum Abgleich, ob Production wirklich neu gebaut wurde */
const vercelGitSha = process.env.VERCEL_GIT_COMMIT_SHA?.trim() ?? "";
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {vercelGitSha && <meta name="build-git-sha" content={vercelGitSha} />}
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"}
    />
    <meta name="author" content={PRACTICE.practitionerName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={PRACTICE.siteName} />
    {canonicalHref && <meta property="og:url" content={canonicalHref} />}
    {ogImageHref && <meta property="og:image" content={ogImageHref} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImageHref && <meta name="twitter:image" content={ogImageHref} />}
    <meta name="geo.region" content="DE-NW" />
    <meta name="geo.placename" content="Köln" />
    <!-- Calibri Light ist als Systemschrift verfügbar; kein externer Font-Import nötig -->
    {appleTouchIconAbsoluteHref && (
      <link rel="apple-touch-icon" href={appleTouchIconAbsoluteHref} />
    )}

    <style>
      :root {
        /* Praxis-Farbpalette: warmes Cream mit Salbeigrün-Akzent */
        --taupe: #a89888;
        --taupe-deep: #8a7b6d;
        --page: #ede6dc;
        --page-deep: #e2d9ce;
        --cream: #faf7f3;
        --surface: #f5f0e9;
        --ink: #1e1a16;
        --text: #36302a;
        --muted: #7a6f64;
        --border: #ddd5c9;
        --shadow: rgba(28, 20, 12, 0.06);
        --shadow-strong: rgba(28, 20, 12, 0.10);
        /* Akzentfarbe: dunkles Warmbraun (Buttons, aktive Nav) */
        --accent: #4a3428;
        --accent-dark: #362318;
        --accent-light: rgba(74, 52, 40, 0.09);
        /* Zweite Akzentfarbe: warmes Terracotta (Überschriften, Highlights) */
        --accent-2: #ae6e52;
        --accent-2-light: rgba(174, 110, 82, 0.12);
        /* Überblendungen */
        --overlay-taupe: rgba(110, 95, 80, 0.18);
        --overlay-taupe-hover: rgba(74, 52, 40, 0.08);
        --overlay-cream-soft: rgba(250, 247, 243, 0.94);
        --overlay-taupe-card: rgba(74, 52, 40, 0.06);
        --header-fill: rgba(250, 247, 243, 0.97);
        /* Kacheln: weiß für klare Abgrenzung vom Hintergrund */
        --card-bg: #ffffff;
        --card-highlight-bg: #f0ebe2;
        --card-highlight-border: rgba(174, 110, 82, 0.30);
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family: "Calibri Light", Calibri, "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        font-weight: 300;
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(ellipse 60% 40% at 15% 0%, rgba(110,85,65,0.10), transparent 55%),
          radial-gradient(ellipse 50% 35% at 85% 5%, rgba(250,247,243,0.96), transparent 50%),
          linear-gradient(180deg, var(--cream) 0%, var(--page) 55%, var(--page-deep) 100%);
        font-size: 1.12rem;
        color: var(--text);
        line-height: 1.80;
        display: flex;
        flex-direction: column;
      }

      nav,
      main,
      .site-end-logo,
      footer {
        position: relative;
        z-index: 1;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--header-fill);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 8px 28px var(--shadow);
      }

      .nav-inner {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 14px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: flex;
        flex-direction: column;
        gap: 2px;
        text-decoration: none;
        color: var(--text);
        min-width: 0;
      }

      .brand strong {
        font-family: "Calibri Light", Calibri, "Segoe UI", Tahoma, sans-serif;
        font-size: 1.55rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        line-height: 1.2;
        text-transform: uppercase;
      }

      .brand > span {
        font-size: 1.0rem;
        color: var(--muted);
        letter-spacing: 0.10em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--muted);
        transition:
          color 0.2s ease,
          background-color 0.2s ease,
          transform 0.2s ease;
        padding: 10px 16px;
        border-radius: 999px;
        font-weight: 500;
        font-size: 0.95rem;
      }

      .nav-links a:hover {
        color: var(--ink);
        background: var(--overlay-taupe-hover);
        transform: translateY(-1px);
      }

      .nav-links a.active {
        color: #ffffff;
        background: var(--accent);
        font-weight: 600;
      }

      /* Desktop: Navigation in einer Zeile (Basis .nav-links nutzt flex-wrap: wrap) */
      @media (min-width: 769px) {
        .nav-inner {
          flex-wrap: nowrap;
          align-items: center;
        }

        .nav-links {
          flex-wrap: nowrap;
          flex: 1;
          justify-content: flex-end;
          min-width: 0;
        }
      }

      main {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        flex: 1;
      }

      main.layout-default {
        margin-top: 40px;
        margin-bottom: 36px;
        padding: clamp(28px, 4vw, 48px);
        background: var(--surface);
        border-radius: 24px;
        border: 1px solid var(--border);
        box-shadow:
          0 22px 60px var(--shadow),
          0 4px 14px var(--overlay-taupe-card);
      }

      main.layout-stacked {
        margin-top: 40px;
        margin-bottom: 36px;
        padding: 0;
        background: none;
        border: none;
        border-radius: 0;
        box-shadow: none;
      }

      /* Kacheln: global, damit Slotted Inhalt aus Seiten (z. B. index) die Klassen trifft */
      :global(.home-sections) {
        display: flex;
        flex-direction: column;
        gap: 22px;
        width: 100%;
        margin: 0 0 48px;
      }

      :global(main.layout-home .home-sections) {
        width: min(1120px, calc(100% - 32px));
        margin-left: auto;
        margin-right: auto;
      }

      :global(.home-sections section.content-block) {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 22px;
        padding: clamp(24px, 3.5vw, 40px);
        box-shadow:
          0 2px 8px rgba(28, 20, 12, 0.04),
          0 12px 36px rgba(28, 20, 12, 0.07);
      }

      :global(.home-sections section.content-block.highlight) {
        background: var(--card-highlight-bg);
        border-color: var(--card-highlight-border);
        box-shadow:
          0 2px 8px rgba(28, 20, 12, 0.04),
          0 12px 36px rgba(78, 114, 98, 0.10);
      }

      :global(.home-sections hr) {
        display: none;
      }

      :global(.home-sections section.content-block > h2:first-child) {
        margin-top: 0;
      }

      :global(.home-sections section.content-block p:last-child) {
        margin-bottom: 0;
      }

      /* Therapieplatz-Hilfe: Intro zentriert; Kachel-Inhalt linksbündig */
      :global(.therapie-tips header.therapie-intro),
      :global(.therapie-tips header.therapie-intro h1),
      :global(.therapie-tips .therapie-lead) {
        text-align: center !important;
      }

      :global(.therapie-tips section.content-block),
      :global(.therapie-tips section.content-block h2),
      :global(.therapie-tips section.content-block p),
      :global(.therapie-tips section.content-block li) {
        text-align: start !important;
      }

      :global(.therapie-tips section.content-block ul) {
        display: block !important;
        margin: 0.75rem 0 0 !important;
        text-align: start !important;
        padding-left: 1.2rem;
      }

      main.layout-home {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
      }

      :global(h1) {
        font-family: "Calibri Light", Calibri, "Segoe UI", Tahoma, sans-serif;
        font-size: clamp(2.2rem, 3.6vw, 3.0rem);
        font-weight: 300;
        margin: 0 0 16px;
        line-height: 1.18;
        letter-spacing: 0.05em;
        color: var(--ink);
        font-style: normal;
      }

      :global(h2) {
        font-family: "Calibri Light", Calibri, "Segoe UI", Tahoma, sans-serif;
        margin-top: 0;
        margin-bottom: 16px;
        color: var(--accent-2);
        font-size: clamp(1.28rem, 1.8vw, 1.50rem);
        font-weight: 700;
        font-style: italic;
        line-height: 1.28;
        letter-spacing: 0.01em;
      }

      :global(h3) {
        font-family: "Calibri Light", Calibri, "Segoe UI", Tahoma, sans-serif;
        color: var(--text);
        font-size: clamp(1.12rem, 1.7vw, 1.28rem);
        font-weight: 600;
        font-style: normal;
        letter-spacing: 0.02em;
        margin-top: 0;
      }

      :global(p),
      :global(li) {
        font-size: 1.14rem;
        line-height: 1.84;
      }

      /* Fettdruck explizit sicherstellen (wichtig bei Calibri Light weight 300) */
      :global(strong), :global(b) {
        font-weight: 700;
        color: var(--ink);
      }

      /* Highlight-Kachel: Text linksbündig im Blocksatz */
      :global(.home-sections section.content-block.highlight p),
      :global(.home-sections section.content-block.highlight li) {
        text-align: justify;
        hyphens: auto;
        -webkit-hyphens: auto;
      }

      :global(a:not(.cta):not(.brand)) {
        color: var(--ink);
        text-underline-offset: 3px;
      }

      :global(.cta) {
        display: inline-block;
        margin-top: 22px;
        padding: 14px 28px;
        background: var(--accent);
        color: #ffffff;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.98rem;
        letter-spacing: 0.02em;
        box-shadow: 0 8px 22px rgba(74, 52, 40, 0.28);
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          background-color 0.2s ease;
      }

      :global(.cta:hover) {
        transform: translateY(-2px);
        box-shadow: 0 12px 28px rgba(74, 52, 40, 0.36);
        background: var(--accent-dark);
      }

      :global(.follow-text-cta) {
        margin-top: 4px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }

      :global(.follow-text-cta > p) {
        margin: 0;
        text-align: justify;
      }

      :global(.follow-text-cta .cta) {
        margin-top: 0;
      }

      :global(img.content-image) {
        max-width: 100%;
        height: auto;
        border-radius: 16px;
        margin-top: 22px;
        border: 1px solid var(--border);
      }

      .site-end-logo {
        width: min(1120px, calc(100% - 32px));
        margin: 36px auto 0;
        padding: 0 16px 12px;
        text-align: center;
        box-sizing: border-box;
      }

      .site-end-logo-img {
        display: block;
        margin: 0 auto;
        height: auto;
        width: auto;
        max-width: 240px;
        max-height: 80px;
        object-fit: contain;
        /* PNG 1:1 wie Repo-Original; Filter dunkelt auf Braun und wirkt Kanten kräftiger */
        filter:
          brightness(0.71)
          sepia(0.22)
          saturate(2.05)
          hue-rotate(348deg)
          contrast(1.18)
          drop-shadow(0.42px 0 0 rgb(74 61 53 / 0.55))
          drop-shadow(-0.42px 0 0 rgb(74 61 53 / 0.55))
          drop-shadow(0 0.42px 0 rgb(74 61 53 / 0.5))
          drop-shadow(0 -0.42px 0 rgb(74 61 53 / 0.5));
      }

      @media (min-width: 769px) {
        .site-end-logo {
          width: min(1120px, calc(100% - 24px));
          padding: 0 12px 16px;
        }

        .site-end-logo-img {
          max-width: 240px;
          max-height: 80px;
        }
      }

      footer {
        text-align: center;
        margin: 0 auto 28px;
        padding: 0;
        font-size: 0.95rem;
        color: var(--muted);
        width: 100%;
      }

      .footer-links {
        margin: 0;
        text-align: center;
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        margin: 0 8px;
      }

      footer a:hover {
        color: var(--ink);
      }

      /* ── Hamburger-Button: nur auf Mobil sichtbar ── */
      .nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        padding: 8px;
        border: none;
        background: transparent;
        cursor: pointer;
        border-radius: 8px;
        flex-shrink: 0;
      }

      .nav-toggle-bar {
        display: block;
        width: 100%;
        height: 2px;
        background: var(--ink);
        border-radius: 2px;
        transition: transform 0.22s ease, opacity 0.22s ease;
      }

      /* X-Animation wenn offen */
      .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
      }
      .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      @media (max-width: 768px) {
        /* ── Navigation ── */
        .nav-inner {
          flex-wrap: wrap;
          padding: 10px 0;
          gap: 0;
          align-items: center;
          width: calc(100% - 64px);
        }

        /* Brand kompakter auf Handy */
        .brand strong {
          font-size: 1.08rem;
          letter-spacing: 0.05em;
        }

        .brand > span {
          font-size: 0.76rem;
          letter-spacing: 0.06em;
        }

        /* Toggle kleiner, mittig neben dem Brand */
        .nav-toggle {
          display: flex;
          margin-left: auto;
          align-self: center;
          flex-shrink: 0;
          width: 34px;
          height: 34px;
          padding: 6px;
        }

        /* Geöffnetes Menü: Links in einer Zeile */
        .nav-links {
          display: none;
          width: 100%;
          flex-direction: row;
          flex-wrap: wrap;
          justify-content: center;
          gap: 4px;
          padding: 10px 0 6px;
          border-top: 1px solid var(--border);
          margin-top: 10px;
        }

        .nav-links.nav-open {
          display: flex;
        }

        .nav-links a {
          display: inline-block;
          padding: 8px 14px;
          border-radius: 10px;
          font-size: 0.92rem;
          white-space: nowrap;
        }

        /* ── Typografie ── */
        :global(h1) {
          font-size: clamp(2.0rem, 7.5vw, 2.5rem) !important;
          text-align: center !important;
          letter-spacing: 0.04em !important;
          margin-bottom: 8px !important;
        }

        :global(h2) {
          font-size: clamp(1.28rem, 4.5vw, 1.55rem) !important;
          text-align: center !important;
        }

        :global(h3) {
          font-size: clamp(1.05rem, 3.5vw, 1.18rem) !important;
          text-align: center !important;
        }

        /* Blocksatz auf Handy */
        :global(p), :global(li) {
          font-size: 1.10rem !important;
          text-align: justify !important;
          hyphens: auto;
          -webkit-hyphens: auto;
        }

        /* CTA-Buttons zentrieren */
        :global(.cta) {
          display: block;
          width: fit-content;
          margin-left: auto;
          margin-right: auto;
        }

        /* ── Abstände & Kacheln ── */
        :global(.home-sections) {
          gap: 14px;
          margin-bottom: 32px;
        }

        :global(.home-sections section.content-block) {
          border-radius: 16px;
          padding: 20px 18px;
        }

        main.layout-default,
        main.layout-stacked {
          width: calc(100% - 16px);
          margin-top: 14px;
          margin-bottom: 18px;
        }

        main.layout-default {
          border-radius: 16px;
          padding: 20px 18px;
        }

        :global(main.layout-home .home-sections) {
          width: calc(100% - 16px);
        }

        .site-end-logo {
          margin-top: 20px;
          padding-bottom: 8px;
        }

        .site-end-logo-img {
          max-width: 180px;
          max-height: 60px;
        }

        footer {
          margin-bottom: 20px;
          font-size: 0.9rem;
          text-align: center !important;
          width: 100% !important;
          display: block;
        }

        .footer-links {
          text-align: center !important;
          display: block;
          width: 100%;
        }
      }

      /* ── Sehr kleine Screens (≤ 480px) ── */
      @media (max-width: 480px) {
        .nav-inner {
          width: calc(100% - 32px);
        }

        :global(.home-sections section.content-block) {
          padding: 16px 14px;
          border-radius: 14px;
        }

        :global(main.layout-home .home-sections) {
          width: calc(100% - 12px);
        }

        :global(h1) {
          font-size: clamp(1.5rem, 7vw, 1.9rem) !important;
        }
      }
    </style>
    {structuredDataJson && (
      <script type="application/ld+json" set:html={structuredDataJson} />
    )}
    <slot name="head" />
  </head>

  <body>
    <header class="site-header">
      <div class="nav-inner">
        <a href="/" class="brand">
          <strong>Praxis für Psychotherapie</strong>
          <span>{PRACTICE.practitionerName}</span>
        </a>
        <button
          class="nav-toggle"
          aria-label="Navigation öffnen"
          aria-expanded="false"
          aria-controls="main-nav"
          type="button"
        >
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>
        <nav class="nav-links" id="main-nav" aria-label="Hauptnavigation">
          <a href="/" class={isActive("/") ? "active" : ""}>Start</a>
          <a href="/about" class={isActive("/about") ? "active" : ""}>Über mich</a>
          <a href="/services" class={isActive("/services") ? "active" : ""}>Organisatorisches</a>
          <a href="/contact" class={isActive("/contact") ? "active" : ""}>Kontakt</a>
        </nav>
      </div>
    </header>

    <script>
      const btn = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
      const nav = document.getElementById('main-nav');
      if (btn && nav) {
        btn.addEventListener('click', () => {
          const open = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!open));
          btn.setAttribute('aria-label', open ? 'Navigation öffnen' : 'Navigation schließen');
          nav.classList.toggle('nav-open', !open);
        });
        // Close nav when a link is clicked
        nav.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            btn.setAttribute('aria-expanded', 'false');
            btn.setAttribute('aria-label', 'Navigation öffnen');
            nav.classList.remove('nav-open');
          });
        });
      }
    </script>

    <main class={mainLayoutClass}>
      <slot />
    </main>

    <aside class="site-end-logo" aria-label="Praxis-Marke">
      <img
        src={footerMarkSrc}
        alt={`Logo: ${PRACTICE.siteName}`}
        class="site-end-logo-img"
        width={FOOTER_MARK.width}
        height={FOOTER_MARK.height}
        loading="lazy"
        decoding="async"
      />
    </aside>

    <footer>
      <p class="footer-links">
        <a href="/impressum">Impressum</a> ·
        <a href="/datenschutz">Datenschutz</a>
      </p>
    </footer>
  </body>
</html>
