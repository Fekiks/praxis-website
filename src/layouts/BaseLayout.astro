---
import { DEFAULT_META_DESCRIPTION, PRACTICE, PRACTICE_LOGO } from "../site-config";

interface Props {
  title: string;
  description?: string;
  layout?: "default" | "home" | "stacked";
  noindex?: boolean;
}

const { title, description, layout = "default", noindex = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = layout === "home";
const isStacked = layout === "stacked";

const mainLayoutClass = isHome ? "layout-home" : isStacked ? "layout-stacked" : "layout-default";

const metaDescription = (description ?? DEFAULT_META_DESCRIPTION).trim();

const siteBaseHref = Astro.site
  ? Astro.site.href.endsWith("/")
    ? Astro.site.href
    : `${Astro.site.href}/`
  : null;

const pathClean = Astro.url.pathname.replace(/^\/+|\/+$/g, "");
const canonicalRel = pathClean === "" ? "./" : `${pathClean}/`;

const canonicalURL =
  siteBaseHref !== null ? new URL(canonicalRel, siteBaseHref) : null;
const canonicalHref = canonicalURL?.href ?? null;

const rootUrl =
  siteBaseHref !== null ? siteBaseHref.replace(/\/+$/, "") || siteBaseHref : null;

const ogImageHref =
  siteBaseHref !== null
    ? new URL("images/Bild_Katja.jpg", siteBaseHref).href
    : null;

const logoSrc = `${import.meta.env.BASE_URL}${PRACTICE_LOGO.file}`;
const logoAbsoluteHref =
  siteBaseHref !== null ? new URL(PRACTICE_LOGO.file, siteBaseHref).href : null;

const structuredDataJson =
  Astro.site && siteBaseHref && rootUrl && !noindex
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "MedicalBusiness",
            "@id": `${rootUrl}#practice`,
            name: PRACTICE.siteName,
            alternateName: [
              "Psychotherapie Katja Stumper Köln",
              "Psychotherapiepraxis Köln Bayenthal",
            ],
            description: DEFAULT_META_DESCRIPTION.trim(),
            url: rootUrl,
            ...(logoAbsoluteHref
              ? {
                  logo: {
                    "@type": "ImageObject",
                    url: logoAbsoluteHref,
                    width: PRACTICE_LOGO.width,
                    height: PRACTICE_LOGO.height,
                  },
                }
              : {}),
            telephone: PRACTICE.telephone,
            email: PRACTICE.email,
            ...(ogImageHref ? { image: [ogImageHref] } : {}),
            address: {
              "@type": "PostalAddress",
              streetAddress: PRACTICE.streetAddress,
              addressLocality: PRACTICE.addressLocality,
              postalCode: PRACTICE.postalCode,
              addressRegion: PRACTICE.addressRegion,
              addressCountry: PRACTICE.country,
            },
            areaServed: {
              "@type": "City",
              name: "Köln",
              containedInPlace: {
                "@type": "AdministrativeArea",
                name: "Nordrhein-Westfalen",
              },
            },
            currenciesAccepted: "EUR",
            paymentAccepted:
              "Gesetzliche Krankenkassen, Privatversicherung, Selbstzahlung",
            medicalSpecialty: "Psychotherapy",
            knowsAbout: [
              "Verhaltenstherapie",
              "Expositionstherapie",
              "Acceptance and Commitment Therapy",
              "EMDR",
            ],
          },
          {
            "@type": "Person",
            "@id": `${rootUrl}#person`,
            name: PRACTICE.practitionerName,
            jobTitle: "Psychologische Psychotherapeutin",
            worksFor: { "@id": `${rootUrl}#practice` },
          },
        ],
      })
    : null;

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  return currentPath === path || currentPath === `${path}/`;
};
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"}
    />
    <meta name="author" content={PRACTICE.practitionerName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={PRACTICE.siteName} />
    {canonicalHref && <meta property="og:url" content={canonicalHref} />}
    {ogImageHref && <meta property="og:image" content={ogImageHref} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImageHref && <meta name="twitter:image" content={ogImageHref} />}
    <meta name="geo.region" content="DE-NW" />
    <meta name="geo.placename" content="Köln" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    {logoAbsoluteHref && <link rel="apple-touch-icon" href={logoAbsoluteHref} />}

    <style>
      :root {
        --taupe: #c8b9a6;
        --taupe-deep: #b5a492;
        --page: #e8e0d4;
        --cream: #f5f1eb;
        --surface: #faf8f5;
        --ink: #141414;
        --text: #1f1d1b;
        --muted: #5c5650;
        --border: #d4c9bb;
        --shadow: rgba(20, 20, 20, 0.08);
        --shadow-strong: rgba(20, 20, 20, 0.14);
        /* Standard-Kacheln: etwas näher am Seitengrund, weniger harter Kontrast */
        --card-bg: #f5f0e6;
        /* Hervorgehobene Kacheln: etwas dunkler als --page, dezent zum Standard-Kachelton */
        --card-highlight-bg: #e0d6ca;
        --card-highlight-border: rgba(110, 94, 80, 0.4);
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(ellipse 70% 45% at 12% 0%, rgba(200, 185, 166, 0.45), transparent 55%),
          radial-gradient(ellipse 55% 40% at 88% 8%, rgba(250, 248, 245, 0.75), transparent 50%),
          linear-gradient(180deg, var(--cream) 0%, var(--page) 42%, #ddd4c8 100%);
        color: var(--text);
        line-height: 1.7;
        display: flex;
        flex-direction: column;
      }

      nav,
      main,
      footer {
        position: relative;
        z-index: 1;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: rgba(250, 248, 245, 0.9);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 8px 28px var(--shadow);
      }

      .nav-inner {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 14px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: flex;
        align-items: center;
        text-decoration: none;
        color: var(--text);
        min-width: 0;
        flex-shrink: 1;
      }

      .brand-logo {
        display: block;
        height: auto;
        max-height: 52px;
        width: auto;
        max-width: min(300px, 58vw);
        object-fit: contain;
        object-position: left center;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .nav-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--muted);
        transition:
          color 0.2s ease,
          background-color 0.2s ease,
          transform 0.2s ease;
        padding: 10px 16px;
        border-radius: 999px;
        font-weight: 500;
        font-size: 0.95rem;
      }

      .nav-links a:hover {
        color: var(--ink);
        background: rgba(200, 185, 166, 0.35);
        transform: translateY(-1px);
      }

      .nav-links a.active {
        color: var(--surface);
        background: var(--ink);
        font-weight: 600;
      }

      main {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        flex: 1;
      }

      main.layout-default {
        margin-top: 40px;
        margin-bottom: 36px;
        padding: clamp(28px, 4vw, 48px);
        background: var(--surface);
        border-radius: 24px;
        border: 1px solid var(--border);
        box-shadow:
          0 22px 60px var(--shadow),
          0 4px 14px rgba(200, 185, 166, 0.2);
      }

      main.layout-stacked {
        margin-top: 40px;
        margin-bottom: 36px;
        padding: 0;
        background: none;
        border: none;
        border-radius: 0;
        box-shadow: none;
      }

      /* Kacheln: global, damit Slotted Inhalt aus Seiten (z. B. index) die Klassen trifft */
      :global(.home-sections) {
        display: flex;
        flex-direction: column;
        gap: 22px;
        width: 100%;
        margin: 0 0 48px;
      }

      :global(main.layout-home .home-sections) {
        width: min(1120px, calc(100% - 32px));
        margin-left: auto;
        margin-right: auto;
      }

      :global(.home-sections section.content-block) {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 22px;
        padding: clamp(24px, 3.5vw, 40px);
        box-shadow: 0 16px 44px var(--shadow);
      }

      :global(.home-sections section.content-block.highlight) {
        background: var(--card-highlight-bg);
        border-color: var(--card-highlight-border);
        box-shadow: 0 16px 44px var(--shadow);
      }

      :global(.home-sections hr) {
        display: none;
      }

      :global(.home-sections section.content-block > h2:first-child) {
        margin-top: 0;
      }

      :global(.home-sections section.content-block p:last-child) {
        margin-bottom: 0;
      }

      main.layout-home {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
      }

      :global(h1) {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 600;
        margin: 0 0 14px;
        line-height: 1.15;
        letter-spacing: -0.01em;
        color: var(--ink);
      }

      :global(h2) {
        font-family: "Cormorant Garamond", Georgia, serif;
        margin-top: 0;
        margin-bottom: 14px;
        color: var(--ink);
        font-size: clamp(1.45rem, 2.4vw, 1.85rem);
        font-weight: 600;
        line-height: 1.25;
      }

      :global(h3) {
        font-family: "Cormorant Garamond", Georgia, serif;
        color: var(--ink);
        font-size: 1.25rem;
        margin-top: 0;
      }

      :global(p),
      :global(li) {
        font-size: 1.05rem;
      }

      :global(a:not(.cta):not(.brand)) {
        color: var(--ink);
        text-underline-offset: 3px;
      }

      :global(.cta) {
        display: inline-block;
        margin-top: 22px;
        padding: 14px 24px;
        background: var(--ink);
        color: var(--surface);
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.98rem;
        letter-spacing: 0.02em;
        box-shadow: 0 10px 24px var(--shadow-strong);
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          background-color 0.2s ease;
      }

      :global(.cta:hover) {
        transform: translateY(-2px);
        box-shadow: 0 14px 30px var(--shadow-strong);
        background: #2a2826;
      }

      :global(.follow-text-cta) {
        margin-top: 4px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }

      :global(.follow-text-cta > p) {
        margin: 0;
        text-align: justify;
      }

      :global(.follow-text-cta .cta) {
        margin-top: 0;
      }

      :global(img.content-image) {
        max-width: 100%;
        height: auto;
        border-radius: 16px;
        margin-top: 22px;
        border: 1px solid var(--border);
      }

      footer {
        text-align: center;
        margin: 28px 0 30px;
        font-size: 0.95rem;
        color: var(--muted);
      }

      .footer-brand {
        margin-bottom: 14px;
      }

      .footer-logo {
        display: block;
        margin: 0 auto;
        height: auto;
        max-height: 38px;
        width: auto;
        max-width: min(220px, 88vw);
        object-fit: contain;
        opacity: 0.9;
      }

      .footer-links {
        margin: 0;
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        margin: 0 8px;
      }

      footer a:hover {
        color: var(--ink);
      }

      @media (max-width: 768px) {
        .nav-inner {
          flex-direction: column;
          align-items: stretch;
          padding: 12px 0;
          gap: 10px;
        }

        /* Eine Zeile: bei vielen Links horizontal wischen, kein Zeilenumbruch */
        .nav-links {
          flex-wrap: nowrap;
          justify-content: flex-start;
          align-items: center;
          max-width: 100%;
          overflow-x: auto;
          overflow-y: hidden;
          -webkit-overflow-scrolling: touch;
          overscroll-behavior-x: contain;
          gap: 6px;
          padding-bottom: 4px;
          scrollbar-width: thin;
        }

        .nav-links a {
          flex-shrink: 0;
          white-space: nowrap;
          padding: 8px 12px;
        }

        .brand-logo {
          max-height: 46px;
          max-width: min(280px, 100%);
        }

        main.layout-default,
        main.layout-stacked {
          width: calc(100% - 20px);
          margin-top: 16px;
          margin-bottom: 20px;
        }

        main.layout-default {
          border-radius: 18px;
          padding: 24px 20px;
        }

        :global(main.layout-home .home-sections) {
          width: calc(100% - 20px);
        }
      }
    </style>
    {structuredDataJson && (
      <script type="application/ld+json" set:html={structuredDataJson} />
    )}
    <slot name="head" />
  </head>

  <body>
    <header class="site-header">
      <div class="nav-inner">
        <a href="/" class="brand">
          <img
            src={logoSrc}
            alt=""
            class="brand-logo"
            width={PRACTICE_LOGO.width}
            height={PRACTICE_LOGO.height}
            loading="eager"
            decoding="async"
          />
          <span class="sr-only">{PRACTICE.siteName}</span>
        </a>
        <nav class="nav-links" aria-label="Hauptnavigation">
          <a href="/" class={isActive("/") ? "active" : ""}>Start</a>
          <a href="/about" class={isActive("/about") ? "active" : ""}>Über mich</a>
          <a href="/services" class={isActive("/services") ? "active" : ""}>Leistungen</a>
          <a href="/contact" class={isActive("/contact") ? "active" : ""}>Kontakt</a>
        </nav>
      </div>
    </header>

    <main class={mainLayoutClass}>
      <slot />
    </main>

    <footer>
      <div class="footer-brand" aria-hidden="true">
        <img
          src={logoSrc}
          alt=""
          class="footer-logo"
          width={PRACTICE_LOGO.width}
          height={PRACTICE_LOGO.height}
          loading="lazy"
          decoding="async"
        />
      </div>
      <p class="footer-links">
        <a href="/impressum">Impressum</a> ·
        <a href="/datenschutz">Datenschutz</a>
      </p>
    </footer>
  </body>
</html>
