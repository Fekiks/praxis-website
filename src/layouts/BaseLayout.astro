---
interface Props {
  title: string;
  layout?: "default" | "home";
}

const { title, layout = "default" } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = layout === "home";

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  return currentPath === path || currentPath === `${path}/`;
};
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --taupe: #c8b9a6;
        --taupe-deep: #b5a492;
        --page: #e8e0d4;
        --cream: #f5f1eb;
        --surface: #faf8f5;
        --ink: #141414;
        --text: #1f1d1b;
        --muted: #5c5650;
        --border: #d4c9bb;
        --shadow: rgba(20, 20, 20, 0.08);
        --shadow-strong: rgba(20, 20, 20, 0.14);
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(ellipse 70% 45% at 12% 0%, rgba(200, 185, 166, 0.45), transparent 55%),
          radial-gradient(ellipse 55% 40% at 88% 8%, rgba(250, 248, 245, 0.75), transparent 50%),
          linear-gradient(180deg, var(--cream) 0%, var(--page) 42%, #ddd4c8 100%);
        color: var(--text);
        line-height: 1.7;
        display: flex;
        flex-direction: column;
      }

      nav,
      main,
      footer {
        position: relative;
        z-index: 1;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: rgba(250, 248, 245, 0.9);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 8px 28px var(--shadow);
      }

      .nav-inner {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 14px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: flex;
        flex-direction: column;
        gap: 2px;
        text-decoration: none;
        color: var(--text);
        min-width: 0;
      }

      .brand strong {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 1.35rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        line-height: 1.2;
      }

      .brand span {
        font-size: 0.82rem;
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--muted);
        transition:
          color 0.2s ease,
          background-color 0.2s ease,
          transform 0.2s ease;
        padding: 10px 16px;
        border-radius: 999px;
        font-weight: 500;
        font-size: 0.95rem;
      }

      .nav-links a:hover {
        color: var(--ink);
        background: rgba(200, 185, 166, 0.35);
        transform: translateY(-1px);
      }

      .nav-links a.active {
        color: var(--surface);
        background: var(--ink);
        font-weight: 600;
      }

      main {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        flex: 1;
      }

      main.layout-default {
        margin-top: 40px;
        margin-bottom: 36px;
        padding: clamp(28px, 4vw, 48px);
        background: var(--surface);
        border-radius: 24px;
        border: 1px solid var(--border);
        box-shadow:
          0 22px 60px var(--shadow),
          0 4px 14px rgba(200, 185, 166, 0.2);
      }

      main.layout-home {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
      }

      :global(h1) {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 600;
        margin: 0 0 14px;
        line-height: 1.15;
        letter-spacing: -0.01em;
        color: var(--ink);
      }

      :global(h2) {
        font-family: "Cormorant Garamond", Georgia, serif;
        margin-top: 0;
        margin-bottom: 14px;
        color: var(--ink);
        font-size: clamp(1.45rem, 2.4vw, 1.85rem);
        font-weight: 600;
        line-height: 1.25;
      }

      :global(h3) {
        font-family: "Cormorant Garamond", Georgia, serif;
        color: var(--ink);
        font-size: 1.25rem;
        margin-top: 0;
      }

      :global(p),
      :global(li) {
        font-size: 1.05rem;
      }

      :global(a:not(.cta):not(.brand)) {
        color: var(--ink);
        text-underline-offset: 3px;
      }

      :global(.cta) {
        display: inline-block;
        margin-top: 22px;
        padding: 14px 24px;
        background: var(--ink);
        color: var(--surface);
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.98rem;
        letter-spacing: 0.02em;
        box-shadow: 0 10px 24px var(--shadow-strong);
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          background-color 0.2s ease;
      }

      :global(.cta:hover) {
        transform: translateY(-2px);
        box-shadow: 0 14px 30px var(--shadow-strong);
        background: #2a2826;
      }

      :global(img.content-image) {
        max-width: 100%;
        height: auto;
        border-radius: 16px;
        margin-top: 22px;
        border: 1px solid var(--border);
      }

      footer {
        text-align: center;
        margin: 28px 0 30px;
        font-size: 0.95rem;
        color: var(--muted);
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        margin: 0 8px;
      }

      footer a:hover {
        color: var(--ink);
      }

      @media (max-width: 768px) {
        .nav-inner {
          flex-direction: column;
          align-items: flex-start;
          padding: 12px 0;
        }

        .nav-links {
          justify-content: flex-start;
        }

        main.layout-default {
          width: calc(100% - 20px);
          margin-top: 16px;
          margin-bottom: 20px;
          border-radius: 18px;
          padding: 24px 20px;
        }

        .nav-links a {
          padding: 8px 12px;
        }
      }
    </style>
    <slot name="head" />
  </head>

  <body>
    <header class="site-header">
      <div class="nav-inner">
        <a href="/" class="brand">
          <strong>Praxis für Psychotherapie</strong>
          <span>Verhaltenstherapie</span>
        </a>
        <nav class="nav-links" aria-label="Hauptnavigation">
          <a href="/" class={isActive("/") ? "active" : ""}>Start</a>
          <a href="/about" class={isActive("/about") ? "active" : ""}>Über mich</a>
          <a href="/services" class={isActive("/services") ? "active" : ""}>Leistungen</a>
          <a href="/contact" class={isActive("/contact") ? "active" : ""}>Kontakt</a>
        </nav>
      </div>
    </header>

    <main class={isHome ? "layout-home" : "layout-default"}>
      <slot />
    </main>

    <footer>
      <a href="/impressum">Impressum</a> ·
      <a href="/datenschutz">Datenschutz</a>
    </footer>
  </body>
</html>
