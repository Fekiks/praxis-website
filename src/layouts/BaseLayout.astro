---
const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (path) => {
  if (path === "/") return currentPath === "/";
  return currentPath === path || currentPath === `${path}/`;
};
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <style>
      :root {
        --primary: #4d7e78;
        --primary-soft: #dcebe8;
        --accent: #f4f8f7;
        --surface: #ffffff;
        --text: #22302f;
        --muted: #5f6f6d;
        --border: #d7e2df;
        --homepage-bg-image: url("/images/Bild_Praxis_Hintergrund.jpeg");
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(220, 235, 232, 0.95) 0%, rgba(220, 235, 232, 0) 32%),
          radial-gradient(circle at top right, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0) 30%),
          linear-gradient(180deg, #eef5f3 0%, #f7faf9 48%, #edf4f2 100%);
        color: var(--text);
        line-height: 1.7;
        display: flex;
        flex-direction: column;
        position: relative;
        isolation: isolate;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: clamp(84px, 12vh, 112px) clamp(32px, 6vw, 56px) clamp(32px, 6vh, 56px);
        border-radius: clamp(28px, 4vw, 40px);
        background:
          linear-gradient(rgba(248, 250, 249, 0.58), rgba(248, 250, 249, 0.82)),
          var(--homepage-bg-image);
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.45),
          0 26px 80px rgba(77, 126, 120, 0.12);
        filter: saturate(0.88) contrast(0.92);
        opacity: 0.96;
        pointer-events: none;
        z-index: 0;
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        background:
          linear-gradient(180deg, rgba(247, 250, 249, 0.28) 0%, rgba(247, 250, 249, 0.12) 24%, rgba(247, 250, 249, 0.5) 100%),
          radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.58) 0%, rgba(255, 255, 255, 0) 22%),
          radial-gradient(circle at 82% 22%, rgba(220, 235, 232, 0.56) 0%, rgba(220, 235, 232, 0) 26%);
        pointer-events: none;
        z-index: 0;
      }

      nav,
      main,
      footer {
        position: relative;
        z-index: 1;
      }

      nav {
        position: sticky;
        top: 0;
        z-index: 10;
        padding: 14px 24px;
        background: rgba(255, 255, 255, 0.78);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        font-weight: 500;
        box-shadow: 0 10px 28px rgba(34, 48, 47, 0.04);
      }

      nav a {
        text-decoration: none;
        color: var(--muted);
        transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
        padding: 10px 16px;
        border-radius: 999px;
      }

      nav a:hover {
        color: var(--primary);
        background: var(--primary-soft);
        transform: translateY(-1px);
      }

      nav a.active {
        color: #fff;
        background: var(--primary);
        font-weight: 600;
      }

      main {
        width: min(840px, calc(100% - 32px));
        margin: 48px auto 34px;
        padding: clamp(24px, 4vw, 44px);
        background: rgba(255, 255, 255, 0.92);
        border-radius: 20px;
        border: 1px solid rgba(215, 226, 223, 0.82);
        box-shadow:
          0 18px 50px rgba(34, 48, 47, 0.08),
          0 6px 18px rgba(77, 126, 120, 0.06);
        backdrop-filter: blur(4px);
      }

      h1 {
        font-size: clamp(1.9rem, 2.8vw, 2.5rem);
        margin: 0 0 12px;
        line-height: 1.25;
        letter-spacing: -0.01em;
      }

      h2 {
        margin-top: 38px;
        color: var(--primary);
        font-size: clamp(1.25rem, 2.1vw, 1.55rem);
      }

      p,
      li {
        font-size: 1.04rem;
      }

      a {
        color: var(--primary);
        text-underline-offset: 2px;
      }

      .cta {
        display: inline-block;
        margin-top: 18px;
        padding: 12px 20px;
        background: var(--primary);
        color: white;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        box-shadow: 0 8px 18px rgba(77, 126, 120, 0.24);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .cta:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(77, 126, 120, 0.32);
      }

      img {
        max-width: 100%;
        height: auto;
        border-radius: 14px;
        margin-top: 22px;
        border: 1px solid var(--border);
      }

      footer {
        text-align: center;
        margin: auto 0 26px;
        font-size: 0.95rem;
        color: var(--muted);
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        margin: 0 8px;
      }

      footer a:hover {
        color: var(--primary);
      }

      @media (max-width: 768px) {
        body::before {
          inset: 72px 12px 18px;
          border-radius: 24px;
          background-position: center top;
          opacity: 0.88;
        }

        nav {
          position: static;
          padding: 14px 12px;
          flex-wrap: wrap;
          justify-content: flex-start;
          gap: 8px;
        }

        main {
          width: calc(100% - 20px);
          margin: 14px auto 18px;
          border-radius: 14px;
        }

        nav a {
          padding: 8px 12px;
        }
      }
    </style>
  </head>

  <body>
    <nav>
      <a href="/" class={isActive("/") ? "active" : ""}>Start</a>
      <a href="/about" class={isActive("/about") ? "active" : ""}>Über mich</a>
      <a href="/services" class={isActive("/services") ? "active" : ""}>Leistungen</a>
      <a href="/contact" class={isActive("/contact") ? "active" : ""}>Kontakt</a>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <a href="/impressum">Impressum</a> ·
      <a href="/datenschutz">Datenschutz</a>
    </footer>
  </body>
</html>
