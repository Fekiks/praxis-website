---
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <style>
      :root {
        --primary: #6b8f8a;
        --accent: #e8f0ef;
        --text: #2f2f2f;
        --muted: #6d6d6d;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 0;
        background: #f9fbfa;
        color: var(--text);
        line-height: 1.6;
      }

      nav {
        padding: 20px 40px;
        background: white;
        border-bottom: 1px solid #eee;
        display: flex;
        gap: 25px;
        font-weight: 500;
      }

      nav a {
        text-decoration: none;
        color: var(--muted);
        position: relative;
      }

      nav a:hover {
        color: var(--primary);
      }

      /* 👉 AKTIVE SEITE */
      nav a.active {
        color: var(--primary);
        font-weight: 600;
      }

      nav a.active::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -4px;
        width: 100%;
        height: 2px;
        background: var(--primary);
        border-radius: 2px;
      }

      main {
        max-width: 720px;
        margin: 60px auto;
        padding: 40px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      }

      h1 {
        font-size: 2rem;
        margin-bottom: 10px;
        text-align: center; /* 👉 optional: macht "Kontakt" mittig */
      }

      h2 {
        margin-top: 30px;
        color: var(--primary);
      }

      a {
        color: var(--primary);
      }

      .cta {
        display: inline-block;
        margin-top: 15px;
        padding: 10px 18px;
        background: var(--primary);
        color: white;
        border-radius: 6px;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin-top: 20px;
      }

      footer {
        text-align: center;
        margin: 40px 0;
        font-size: 14px;
        color: var(--muted);
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        margin: 0 8px;
      }

      footer a:hover {
        color: var(--primary);
      }

      /* 👉 MOBILE */
      @media (max-width: 768px) {
        nav {
          padding: 15px 20px;
          flex-wrap: wrap;
          gap: 10px;
        }

        main {
          margin: 20px;
          padding: 20px;
        }

        h1 {
          font-size: 1.5rem;
        }

        h2 {
          font-size: 1.2rem;
        }
      }
    </style>
  </head>

  <body>
    <nav>
      <a href="/" class={currentPath === "/" ? "active" : ""}>Start</a>
      <a href="/about" class={currentPath === "/about" ? "active" : ""}>Über mich</a>
      <a href="/services" class={currentPath === "/services" ? "active" : ""}>Leistungen</a>
      <a href="/contact" class={currentPath === "/contact" ? "active" : ""}>Kontakt</a>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <a href="/impressum">Impressum</a> ·
      <a href="/datenschutz">Datenschutz</a>
    </footer>
  </body>
</html>