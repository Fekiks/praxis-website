---
const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (path) => {
  if (path === "/") return currentPath === "/";
  return currentPath === path || currentPath === `${path}/`;
};
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <style>
      :root {
        --primary: #4d7e78;
        --primary-soft: #dcebe8;
        --accent: #f4f8f7;
        --surface: #ffffff;
        --text: #22302f;
        --muted: #5f6f6d;
        --border: #d7e2df;
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, #eef5f3 0%, transparent 35%),
          radial-gradient(circle at top right, #eff6f5 0%, transparent 30%),
          var(--accent);
        color: var(--text);
        line-height: 1.7;
        display: flex;
        flex-direction: column;
      }

      nav {
        position: sticky;
        top: 0;
        z-index: 10;
        padding: 14px 24px;
        background: rgba(255, 255, 255, 0.88);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        font-weight: 500;
      }

      nav a {
        text-decoration: none;
        color: var(--muted);
        transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
        padding: 10px 16px;
        border-radius: 999px;
      }

      nav a:hover {
        color: var(--primary);
        background: var(--primary-soft);
        transform: translateY(-1px);
      }

      nav a.active {
        color: #fff;
        background: var(--primary);
        font-weight: 600;
      }

      main {
        width: min(840px, calc(100% - 32px));
        margin: 54px auto 34px;
        padding: clamp(24px, 4vw, 44px);
        background: var(--surface);
        border-radius: 20px;
        border: 1px solid var(--border);
        box-shadow: 0 16px 45px rgba(34, 48, 47, 0.08);
      }

      h1 {
        font-size: clamp(1.9rem, 2.8vw, 2.5rem);
        margin: 0 0 12px;
        line-height: 1.25;
        letter-spacing: -0.01em;
      }

      h2 {
        margin-top: 38px;
        color: var(--primary);
        font-size: clamp(1.25rem, 2.1vw, 1.55rem);
      }

      p,
      li {
        font-size: 1.04rem;
      }

      a {
        color: var(--primary);
        text-underline-offset: 2px;
      }

      .cta {
        display: inline-block;
        margin-top: 18px;
        padding: 12px 20px;
        background: var(--primary);
        color: white;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        box-shadow: 0 8px 18px rgba(77, 126, 120, 0.24);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .cta:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(77, 126, 120, 0.32);
      }

      img {
        max-width: 100%;
        height: auto;
        border-radius: 14px;
        margin-top: 22px;
        border: 1px solid var(--border);
      }

      footer {
        text-align: center;
        margin: auto 0 26px;
        font-size: 0.95rem;
        color: var(--muted);
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        margin: 0 8px;
      }

      footer a:hover {
        color: var(--primary);
      }

      @media (max-width: 768px) {
        nav {
          position: static;
          padding: 14px 12px;
          flex-wrap: wrap;
          justify-content: flex-start;
          gap: 8px;
        }

        main {
          width: calc(100% - 20px);
          margin: 14px auto 18px;
          border-radius: 14px;
        }

        nav a {
          padding: 8px 12px;
        }
      }
    </style>
  </head>

  <body>
    <nav>
      <a href="/" class={isActive("/") ? "active" : ""}>Start</a>
      <a href="/about" class={isActive("/about") ? "active" : ""}>Über mich</a>
      <a href="/services" class={isActive("/services") ? "active" : ""}>Leistungen</a>
      <a href="/contact" class={isActive("/contact") ? "active" : ""}>Kontakt</a>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <a href="/impressum">Impressum</a> ·
      <a href="/datenschutz">Datenschutz</a>
    </footer>
  </body>
</html>
