---
import footerMark from "../assets/footer/footer_praxis_mark.png";
import { DEFAULT_META_DESCRIPTION, PRACTICE } from "../site-config";

interface Props {
  title: string;
  description?: string;
  layout?: "default" | "home" | "stacked";
  noindex?: boolean;
}

const { title, description, layout = "default", noindex = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = layout === "home";
const isStacked = layout === "stacked";

const mainLayoutClass = isHome ? "layout-home" : isStacked ? "layout-stacked" : "layout-default";

const metaDescription = (description ?? DEFAULT_META_DESCRIPTION).trim();

const siteBaseHref = Astro.site
  ? Astro.site.href.endsWith("/")
    ? Astro.site.href
    : `${Astro.site.href}/`
  : null;

const pathClean = Astro.url.pathname.replace(/^\/+|\/+$/g, "");
const canonicalRel = pathClean === "" ? "./" : `${pathClean}/`;

const canonicalURL =
  siteBaseHref !== null ? new URL(canonicalRel, siteBaseHref) : null;
const canonicalHref = canonicalURL?.href ?? null;

const rootUrl =
  siteBaseHref !== null ? siteBaseHref.replace(/\/+$/, "") || siteBaseHref : null;

const logoSrc = footerMark.src;
const logoAbsoluteHref =
  siteBaseHref !== null ? new URL(footerMark.src, siteBaseHref).href : null;

/** Social / Link-Vorschau (og:image, twitter:image) — Praxislogo statt Porträt */
const ogImageHref = logoAbsoluteHref;

const structuredDataJson =
  Astro.site && siteBaseHref && rootUrl && !noindex
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "MedicalBusiness",
            "@id": `${rootUrl}#practice`,
            name: PRACTICE.siteName,
            alternateName: [
              "Psychotherapie Katja Stumper Köln",
              "Psychotherapiepraxis Köln Bayenthal",
            ],
            description: DEFAULT_META_DESCRIPTION.trim(),
            url: rootUrl,
            ...(logoAbsoluteHref
              ? {
                  logo: {
                    "@type": "ImageObject",
                    url: logoAbsoluteHref,
                    width: footerMark.width,
                    height: footerMark.height,
                  },
                }
              : {}),
            telephone: PRACTICE.telephone,
            email: PRACTICE.email,
            ...(ogImageHref ? { image: [ogImageHref] } : {}),
            address: {
              "@type": "PostalAddress",
              streetAddress: PRACTICE.streetAddress,
              addressLocality: PRACTICE.addressLocality,
              postalCode: PRACTICE.postalCode,
              addressRegion: PRACTICE.addressRegion,
              addressCountry: PRACTICE.country,
            },
            areaServed: {
              "@type": "City",
              name: "Köln",
              containedInPlace: {
                "@type": "AdministrativeArea",
                name: "Nordrhein-Westfalen",
              },
            },
            currenciesAccepted: "EUR",
            paymentAccepted:
              "Gesetzliche Krankenkassen, Privatversicherung, Selbstzahlung",
            medicalSpecialty: "Psychotherapy",
            knowsAbout: [
              "Verhaltenstherapie",
              "Expositionstherapie",
              "Acceptance and Commitment Therapy",
              "EMDR",
            ],
          },
          {
            "@type": "Person",
            "@id": `${rootUrl}#person`,
            name: PRACTICE.practitionerName,
            jobTitle: "Psychologische Psychotherapeutin",
            worksFor: { "@id": `${rootUrl}#practice` },
          },
        ],
      })
    : null;

const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";

const isActive = (path: string) => {
  const cur = normalizePath(currentPath);
  const target = normalizePath(path);
  if (target === "/") return cur === "/";
  return cur === target || cur.startsWith(`${target}/`);
};

/** Nur bei Vercel-Build gesetzt – zum Abgleich, ob Production wirklich neu gebaut wurde */
const vercelGitSha = process.env.VERCEL_GIT_COMMIT_SHA?.trim() ?? "";
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    {vercelGitSha && <meta name="build-git-sha" content={vercelGitSha} />}
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"}
    />
    <meta name="author" content={PRACTICE.practitionerName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={PRACTICE.siteName} />
    {canonicalHref && <meta property="og:url" content={canonicalHref} />}
    {ogImageHref && <meta property="og:image" content={ogImageHref} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImageHref && <meta name="twitter:image" content={ogImageHref} />}
    <meta name="geo.region" content="DE-NW" />
    <meta name="geo.placename" content="Köln" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    {logoAbsoluteHref && <link rel="apple-touch-icon" href={logoAbsoluteHref} />}

    <style>
      :root {
        /*
          Praxis-Farbpalette: warm Sand/Pergament, ruhige Tiefe –
          wirkt professionell ohne Klinikkühle.
        */
        --taupe: #ad9f8f;
        --taupe-deep: #8f8374;
        --page: #cfc0b5;
        --page-deep: #bfb0a4;
        --cream: #faf7f2;
        --surface: #fffdfa;
        --ink: #1f1b17;
        --text: #2e2721;
        --muted: #5f534a;
        --border: #c4b6a9;
        --shadow: rgba(32, 24, 18, 0.075);
        --shadow-strong: rgba(32, 24, 18, 0.13);
        /* Überblendungen: Radiale, Hover, Kartenschatten */
        --overlay-taupe: rgba(158, 140, 124, 0.36);
        --overlay-taupe-hover: rgba(158, 140, 124, 0.32);
        --overlay-cream-soft: rgba(250, 247, 242, 0.9);
        --overlay-taupe-card: rgba(158, 140, 124, 0.2);
        --header-fill: rgba(250, 247, 242, 0.94);
        --card-bg: #f9f6f1;
        --card-highlight-bg: #ebe1d8;
        --card-highlight-border: rgba(92, 76, 65, 0.36);
      }

      * {
        box-sizing: border-box;
      }

      body {
        font-family: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(ellipse 70% 45% at 12% 0%, var(--overlay-taupe), transparent 55%),
          radial-gradient(ellipse 55% 40% at 88% 8%, var(--overlay-cream-soft), transparent 50%),
          linear-gradient(180deg, var(--cream) 0%, var(--page) 42%, var(--page-deep) 100%);
        color: var(--text);
        line-height: 1.7;
        display: flex;
        flex-direction: column;
      }

      nav,
      main,
      .site-end-logo,
      footer {
        position: relative;
        z-index: 1;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--header-fill);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 8px 28px var(--shadow);
      }

      .nav-inner {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 14px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: flex;
        flex-direction: column;
        gap: 2px;
        text-decoration: none;
        color: var(--text);
        min-width: 0;
      }

      .brand strong {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 1.35rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        line-height: 1.2;
      }

      .brand > span {
        font-size: 0.82rem;
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center;
        gap: 8px;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--muted);
        transition:
          color 0.2s ease,
          background-color 0.2s ease,
          transform 0.2s ease;
        padding: 10px 16px;
        border-radius: 999px;
        font-weight: 500;
        font-size: 0.95rem;
      }

      .nav-links a:hover {
        color: var(--ink);
        background: var(--overlay-taupe-hover);
        transform: translateY(-1px);
      }

      .nav-links a.active {
        color: var(--surface);
        background: var(--ink);
        font-weight: 600;
      }

      /* Desktop: Navigation in einer Zeile (Basis .nav-links nutzt flex-wrap: wrap) */
      @media (min-width: 769px) {
        .nav-inner {
          flex-wrap: nowrap;
          align-items: center;
        }

        .nav-links {
          flex-wrap: nowrap;
          flex: 1;
          justify-content: flex-end;
          min-width: 0;
        }
      }

      main {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        flex: 1;
      }

      main.layout-default {
        margin-top: 40px;
        margin-bottom: 36px;
        padding: clamp(28px, 4vw, 48px);
        background: var(--surface);
        border-radius: 24px;
        border: 1px solid var(--border);
        box-shadow:
          0 22px 60px var(--shadow),
          0 4px 14px var(--overlay-taupe-card);
      }

      main.layout-stacked {
        margin-top: 40px;
        margin-bottom: 36px;
        padding: 0;
        background: none;
        border: none;
        border-radius: 0;
        box-shadow: none;
      }

      /* Kacheln: global, damit Slotted Inhalt aus Seiten (z. B. index) die Klassen trifft */
      :global(.home-sections) {
        display: flex;
        flex-direction: column;
        gap: 22px;
        width: 100%;
        margin: 0 0 48px;
      }

      :global(main.layout-home .home-sections) {
        width: min(1120px, calc(100% - 32px));
        margin-left: auto;
        margin-right: auto;
      }

      :global(.home-sections section.content-block) {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 22px;
        padding: clamp(24px, 3.5vw, 40px);
        box-shadow: 0 16px 44px var(--shadow);
      }

      :global(.home-sections section.content-block.highlight) {
        background: var(--card-highlight-bg);
        border-color: var(--card-highlight-border);
        box-shadow: 0 16px 44px var(--shadow);
      }

      :global(.home-sections hr) {
        display: none;
      }

      :global(.home-sections section.content-block > h2:first-child) {
        margin-top: 0;
      }

      :global(.home-sections section.content-block p:last-child) {
        margin-bottom: 0;
      }

      /* Therapieplatz-Hilfe: Intro zentriert; Kachel-Inhalt linksbündig */
      :global(.therapie-tips header.therapie-intro),
      :global(.therapie-tips header.therapie-intro h1),
      :global(.therapie-tips .therapie-lead) {
        text-align: center !important;
      }

      :global(.therapie-tips section.content-block),
      :global(.therapie-tips section.content-block h2),
      :global(.therapie-tips section.content-block p),
      :global(.therapie-tips section.content-block li) {
        text-align: start !important;
      }

      :global(.therapie-tips section.content-block ul) {
        display: block !important;
        margin: 0.75rem 0 0 !important;
        text-align: start !important;
        padding-left: 1.2rem;
      }

      main.layout-home {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
      }

      :global(h1) {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(2rem, 3.4vw, 2.85rem);
        font-weight: 600;
        margin: 0 0 14px;
        line-height: 1.15;
        letter-spacing: -0.01em;
        color: var(--ink);
      }

      :global(h2) {
        font-family: "Cormorant Garamond", Georgia, serif;
        margin-top: 0;
        margin-bottom: 14px;
        color: var(--ink);
        font-size: clamp(1.45rem, 2.4vw, 1.85rem);
        font-weight: 600;
        line-height: 1.25;
      }

      :global(h3) {
        font-family: "Cormorant Garamond", Georgia, serif;
        color: var(--ink);
        font-size: 1.25rem;
        margin-top: 0;
      }

      :global(p),
      :global(li) {
        font-size: 1.05rem;
      }

      :global(a:not(.cta):not(.brand)) {
        color: var(--ink);
        text-underline-offset: 3px;
      }

      :global(.cta) {
        display: inline-block;
        margin-top: 22px;
        padding: 14px 24px;
        background: var(--ink);
        color: var(--surface);
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.98rem;
        letter-spacing: 0.02em;
        box-shadow: 0 10px 24px var(--shadow-strong);
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          background-color 0.2s ease;
      }

      :global(.cta:hover) {
        transform: translateY(-2px);
        box-shadow: 0 14px 30px var(--shadow-strong);
        background: #3a342f;
      }

      :global(.follow-text-cta) {
        margin-top: 4px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }

      :global(.follow-text-cta > p) {
        margin: 0;
        text-align: justify;
      }

      :global(.follow-text-cta .cta) {
        margin-top: 0;
      }

      :global(img.content-image) {
        max-width: 100%;
        height: auto;
        border-radius: 16px;
        margin-top: 22px;
        border: 1px solid var(--border);
      }

      /*
        Fußbereichs-Logo (importiert aus `src/assets/footer/`, läuft als `/_astro/…`).
      */
      .site-end-logo {
        width: min(1120px, calc(100% - 32px));
        margin: 36px auto 0;
        padding: 0 16px 12px;
        text-align: center;
        box-sizing: border-box;
      }

      .site-end-logo-img {
        display: block;
        margin: 0 auto;
        height: auto;
        width: auto;
        max-width: min(296px, 88vw);
        max-height: 90px;
        object-fit: contain;
        opacity: 1;
        transform-origin: center;
        transform: scaleX(1.095);
      }

      @media (min-width: 769px) {
        .site-end-logo {
          width: min(1120px, calc(100% - 24px));
          padding: 0 12px 16px;
        }

        .site-end-logo-img {
          width: auto;
          max-width: min(408px, 58vw);
          max-height: 178px;
          transform: scaleX(1.102);
        }
      }

      footer {
        text-align: center;
        margin: 0 0 28px;
        padding: 0;
        font-size: 0.95rem;
        color: var(--muted);
      }

      .footer-links {
        margin: 0;
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        margin: 0 8px;
      }

      footer a:hover {
        color: var(--ink);
      }

      @media (max-width: 768px) {
        .nav-inner {
          flex-direction: column;
          align-items: stretch;
          padding: 12px 0;
          gap: 10px;
        }

        /* Eine Zeile: bei vielen Links horizontal wischen, kein Zeilenumbruch */
        .nav-links {
          flex-wrap: nowrap;
          justify-content: flex-start;
          align-items: center;
          max-width: 100%;
          overflow-x: auto;
          overflow-y: hidden;
          -webkit-overflow-scrolling: touch;
          overscroll-behavior-x: contain;
          gap: 6px;
          padding-bottom: 4px;
          scrollbar-width: thin;
        }

        .nav-links a {
          flex-shrink: 0;
          white-space: nowrap;
          padding: 8px 12px;
        }

        main.layout-default,
        main.layout-stacked {
          width: calc(100% - 20px);
          margin-top: 16px;
          margin-bottom: 20px;
        }

        main.layout-default {
          border-radius: 18px;
          padding: 24px 20px;
        }

        :global(main.layout-home .home-sections) {
          width: calc(100% - 20px);
        }

        .site-end-logo {
          margin-top: 28px;
          padding-bottom: 10px;
        }

        .site-end-logo-img {
          width: auto;
          max-width: min(268px, 84vw);
          max-height: 78px;
          transform: scaleX(1.09);
        }
      }
    </style>
    {structuredDataJson && (
      <script type="application/ld+json" set:html={structuredDataJson} />
    )}
    <slot name="head" />
  </head>

  <body>
    <header class="site-header">
      <div class="nav-inner">
        <a href="/" class="brand">
          <strong>Praxis für Psychotherapie</strong>
          <span>{PRACTICE.practitionerName}</span>
        </a>
        <nav class="nav-links" aria-label="Hauptnavigation">
          <a href="/" class={isActive("/") ? "active" : ""}>Start</a>
          <a href="/about" class={isActive("/about") ? "active" : ""}>Über mich</a>
          <a href="/services" class={isActive("/services") ? "active" : ""}>Leistungen</a>
          <a href="/contact" class={isActive("/contact") ? "active" : ""}>Kontakt</a>
        </nav>
      </div>
    </header>

    <main class={mainLayoutClass}>
      <slot />
    </main>

    <aside class="site-end-logo">
      <img
        src={logoSrc}
        alt={`Logo: ${PRACTICE.siteName}`}
        class="site-end-logo-img"
        width={footerMark.width}
        height={footerMark.height}
        loading="lazy"
        decoding="async"
      />
    </aside>

    <footer>
      <p class="footer-links">
        <a href="/impressum">Impressum</a> ·
        <a href="/datenschutz">Datenschutz</a>
      </p>
    </footer>
  </body>
</html>
